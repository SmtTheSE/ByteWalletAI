# ByteWallet AI — environment config
# Copy this file to .env and fill in your values

# Ollama (local LLM — required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AI mode: "local_only" (Ollama only) | "rules_only" (no LLM, fastest)
AI_DEFAULT_MODE=local_only

# Kaggle API credentials (needed to download training datasets)
# Get yours at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
