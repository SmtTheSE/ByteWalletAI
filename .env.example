# ByteWallet AI — environment config
# Copy this file to .env and fill in your values

# ByteWallet AI - Environment Configuration

# AI mode: only rules_only is supported
AI_DEFAULT_MODE=rules_only

# Kaggle API credentials (needed to download training datasets)
# Get yours at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
