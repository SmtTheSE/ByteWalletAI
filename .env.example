# ByteWallet AI — environment config
# Copy this file to .env and fill in your values

# ── Core AI mode ──────────────────────────────────────────────────────────────
# Options: "rules_only" | "local_only" | "auto"
AI_DEFAULT_MODE=rules_only

# ── Kaggle API (for training data download) ───────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Phase 1: Gemini NL Function Calling ──────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Phase 2: RAG (ChromaDB vector store) ─────────────────────────────────────
RAG_ENABLED=true
RAG_TOP_K=5

# ── Phase 5: Federated Learning ───────────────────────────────────────────────
# Set min clients before FedAvg aggregation triggers (default: 3)
FED_MIN_CLIENTS=3
